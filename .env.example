# Global daily leaderboard (optional — game stays local-only without these).
# Setup steps: see supabase/schema.sql
VITE_LB_URL=https://your-project.supabase.co
VITE_LB_KEY=your-anon-public-key

# On-chain signup + race tracking (MiniRushTracker on Celo mainnet). Optional —
# without it the game runs fine, on-chain writes just no-op. See contracts/.
# The deployed default is baked into src/wallet.ts; override it here if you
# deploy your own instance.
VITE_TRACKER_ADDRESS=0xYourDeployedMiniRushTracker
